    height = float(input("Enter the height from which the object is dropped (m): "))
    if height >= 0:
      break
    print("Enter a positive value")
  except ValueError:
    print("Invalid! Enter a proper value.")
    
final_velocity = (2 * acceleration_due_to_gravity * height) ** 0.5
