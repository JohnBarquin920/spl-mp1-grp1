import math 
s1 = input("Please input the first side of your triangle: ") 
s1 = int(s1) 
s2 = input("Please input the second side of your triangle: ") 
s2 = int(s2) 
s3 = input("Please input the third side of your triangle: ") 
s3 = int(s3) 
s = (s1 + s2 + s3)/2 
area = math.sqrt(s * (s - s1) * (s - s2) * (s - s3)) 
print(s1) 
print(s2) 
print(s3) 
print(area) 
