print("EXERCISE 16: AREA AND VOLUME\n") 

import math 
radius = float(input("Enter the radius here: ")) 

area = math.pi * radius ** 2 

volume = (4/3) * math.pi * radius ** 3 

print(f"\nThe area of a circle with a radius of {radius} is {area:.2f} square units.") 

print(f"The volume of a sphere with a radius of {radius} is {volume:.2f} cubic units.") 
